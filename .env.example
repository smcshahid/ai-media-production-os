# AIMPOS-Spark Visual — Environment Template
# Copy to .env and fill real values. NEVER commit .env (gitignored).

# --- API ---
API_PORT=8000
AIMPOS_API_TOKEN=change-me-local-dev-token

# --- PostgreSQL (US-04) ---
POSTGRES_USER=aimpos
POSTGRES_PASSWORD=change-me-local-dev-password
POSTGRES_DB=aimpos_spark
POSTGRES_HOST=postgresql
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://aimpos:change-me-local-dev-password@postgresql:5432/aimpos_spark

# --- MinIO (US-05) ---
MINIO_ROOT_USER=aimpos
MINIO_ROOT_PASSWORD=change-me-local-dev-password
MINIO_ENDPOINT=minio:9000
MINIO_BUCKET=aimpos-hot-assets
MINIO_SECURE=false

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- Web (US-26) ---
# Local docker web talks to the local API container on :8000.
# (Olares-desktop-only mode uses VITE_API_URL=http://localhost:18000 instead.)
VITE_API_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:5173
WEB_PORT=5173

# --- Temporal ---
TEMPORAL_ADDRESS=temporal:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=aimpos-spark-pipeline
TEMPORAL_PORT=7233
TEMPORAL_UI_PORT=8080

# --- Ollama / ComfyUI ---
# Daily dev (`make up-dev`): worker always uses Olares shared AI (24GB GPU) via SSH
# tunnels on localhost:11434 and :8190. Values below are for reference; docker-compose.dev.yml
# hardcodes the worker endpoints so a stale .env cannot route to missing local AI services.
OLLAMA_HOST=http://host.docker.internal:11434
OLLAMA_PORT=11434
OLLAMA_MODEL=qwen3:14b
COMFYUI_HOST=http://host.docker.internal:8190
COMFYUI_PORT=8190
AIMPOS_CONFIG_ROOT=configs

# --- ComfyUI storyboard image quality (D-60) ---
# Storyboard image engine = which workflow JSON to run (configs/comfyui/workflows/).
# Each engine ships its own correct sampler params, so just switch the file:
#   flux_storyboard.json        - Flux.1-dev (best cinematic; NON-COMMERCIAL license)  <- GPU default
#   zimage_storyboard.json      - Z-Image Turbo (excellent + fast 8-step; permissive license)
#   sdxl_realvis_storyboard.json- RealVisXL V5 photoreal SDXL (commercial-friendly)
#   sdxl_storyboard_v2.json     - base SDXL 1.0 hi-res-fix (local-ai profile only)
# `make up-dev` hardcodes flux_storyboard.json on the worker.
COMFYUI_WORKFLOW=flux_storyboard.json
COMFYUI_WIDTH=1344
COMFYUI_HEIGHT=768
COMFYUI_GENERATE_TIMEOUT_S=180
# Optional sampler overrides (leave unset to use the engine workflow's own values).
# Only uncomment to force-tune a specific workflow; mismatched values can degrade output
# (e.g. SDXL wants cfg ~7, Flux/Z-Image want cfg 1). To take effect they must also be
# added to the worker service `environment:` block.
# COMFYUI_STEPS=28
# COMFYUI_HIRES_STEPS=12
# COMFYUI_CFG=7.0
# COMFYUI_SAMPLER=dpmpp_2m_sde
# COMFYUI_SCHEDULER=karras

# --- ComfyUI WAN 2.2 image-to-video (D-61) ---
# Requires WAN 2.2 weights on the Olares ComfyUI host (scripts/dev/provision-olares-comfyui-models.ps1).
# `make up-dev` enables i2v on the worker; set false here only for local-ai profile testing.
VIDEO_I2V_ENABLED=true
VIDEO_I2V_WORKFLOW=wan22_i2v.json
VIDEO_I2V_WIDTH=832
VIDEO_I2V_HEIGHT=480
VIDEO_I2V_FRAMES=81
VIDEO_I2V_FPS=16
VIDEO_I2V_STEPS=20
VIDEO_I2V_TIMEOUT_S=1200

# --- Olares desktop (optional overrides) ---
OLARES_HOST=olares@10.0.0.34
OLARES_API_CLUSTER_IP=10.233.21.231
OLARES_API_LOCAL_PORT=18000
