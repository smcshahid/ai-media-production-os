# AIMPOS-Spark Visual — Environment Template
# Copy to .env and fill real values. NEVER commit .env (gitignored).
# Sprint 0 core + Sprint 1 infra (Temporal, Ollama, ComfyUI). GPU services need NVIDIA.

# --- API ---
API_PORT=8000
# Static Bearer token for Sprint 0 auth (US-25). Rotate by changing this value and restarting the API.
AIMPOS_API_TOKEN=change-me-local-dev-token

# --- PostgreSQL (US-04) ---
POSTGRES_USER=aimpos
POSTGRES_PASSWORD=change-me-local-dev-password
POSTGRES_DB=aimpos_spark
POSTGRES_HOST=postgresql
POSTGRES_PORT=5432
# Full SQLAlchemy/Alembic connection string
DATABASE_URL=postgresql+psycopg://aimpos:change-me-local-dev-password@postgresql:5432/aimpos_spark

# --- MinIO (US-05) ---
MINIO_ROOT_USER=aimpos
MINIO_ROOT_PASSWORD=change-me-local-dev-password
MINIO_ENDPOINT=minio:9000
MINIO_BUCKET=aimpos-hot-assets
MINIO_SECURE=false

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- Web (US-26) ---
# Base URL the SPA uses to reach the API (baked into the build / read by Vite).
VITE_API_URL=http://localhost:8000
# Comma-separated browser origins the API allows via CORS (the SPA's origin).
CORS_ORIGINS=http://localhost:5173
WEB_PORT=5173

# --- Temporal (Sprint 1) ---
TEMPORAL_ADDRESS=temporal:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=aimpos-spark-pipeline
TEMPORAL_PORT=7233
TEMPORAL_UI_PORT=8080

# --- Ollama (Sprint 1 — requires GPU) ---
OLLAMA_HOST=http://ollama:11434
OLLAMA_PORT=11434
OLLAMA_MODEL=qwen3:14b
AIMPOS_CONFIG_ROOT=configs

# --- ComfyUI (Sprint 1 — requires GPU) ---
COMFYUI_PORT=8188
