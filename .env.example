# AIMPOS-Spark Visual — Environment Template
# Copy to .env and fill real values. NEVER commit .env (gitignored).
# Sprint 0 services only: PostgreSQL, MinIO, Redis, API. Ollama/ComfyUI/Temporal arrive in Sprint 1.

# --- API ---
API_PORT=8000
# Static Bearer token for Sprint 0 auth (US-25). Rotate by changing this value and restarting the API.
AIMPOS_API_TOKEN=change-me-local-dev-token

# --- PostgreSQL (US-04) ---
POSTGRES_USER=aimpos
POSTGRES_PASSWORD=change-me-local-dev-password
POSTGRES_DB=aimpos_spark
POSTGRES_HOST=postgresql
POSTGRES_PORT=5432
# Full SQLAlchemy/Alembic connection string
DATABASE_URL=postgresql+psycopg://aimpos:change-me-local-dev-password@postgresql:5432/aimpos_spark

# --- MinIO (US-05) ---
MINIO_ROOT_USER=aimpos
MINIO_ROOT_PASSWORD=change-me-local-dev-password
MINIO_ENDPOINT=minio:9000
MINIO_BUCKET=aimpos-spark
MINIO_SECURE=false

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- Web (US-26) ---
VITE_API_URL=http://localhost:8000
