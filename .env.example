# AIMPOS-Spark Visual — Environment Template
# Copy to .env and fill real values. NEVER commit .env (gitignored).

# --- API ---
API_PORT=8000
AIMPOS_API_TOKEN=change-me-local-dev-token

# --- PostgreSQL (US-04) ---
POSTGRES_USER=aimpos
POSTGRES_PASSWORD=change-me-local-dev-password
POSTGRES_DB=aimpos_spark
POSTGRES_HOST=postgresql
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://aimpos:change-me-local-dev-password@postgresql:5432/aimpos_spark

# --- MinIO (US-05) ---
MINIO_ROOT_USER=aimpos
MINIO_ROOT_PASSWORD=change-me-local-dev-password
MINIO_ENDPOINT=minio:9000
MINIO_BUCKET=aimpos-hot-assets
MINIO_SECURE=false

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- Web (US-26) ---
# Desktop → Olares (recommended): scripts/dev/start-olares-desktop.ps1
#   VITE_API_URL=http://localhost:18000  (SSH tunnel to Olares API)
# Local full stack: VITE_API_URL=http://localhost:8000
VITE_API_URL=http://localhost:18000
CORS_ORIGINS=http://localhost:5173
WEB_PORT=5173

# --- Temporal ---
TEMPORAL_ADDRESS=temporal:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=aimpos-spark-pipeline
TEMPORAL_PORT=7233
TEMPORAL_UI_PORT=8080

# --- Ollama / ComfyUI ---
# Default compose stack: local-ai profile (make up-dev-ai).
# Olares hybrid (local app + shared AI): use docker-compose.olares-hybrid.yml
#   + scripts/dev/start-olares-tunnels.ps1 -AiOnly
OLLAMA_HOST=http://host.docker.internal:11434
OLLAMA_PORT=11434
OLLAMA_MODEL=qwen3:14b
COMFYUI_HOST=http://host.docker.internal:8190
COMFYUI_PORT=8190
AIMPOS_CONFIG_ROOT=configs

# --- ComfyUI storyboard image quality (D-60) ---
# Hi-res 16:9 SDXL workflow with a hi-res-fix second pass. All params are tunable;
# defaults target the Olares 24GB GPU. Use sdxl_storyboard_production.json to revert.
COMFYUI_WORKFLOW=sdxl_storyboard_v2.json
COMFYUI_WIDTH=1344
COMFYUI_HEIGHT=768
COMFYUI_STEPS=28
COMFYUI_HIRES_STEPS=12
COMFYUI_CFG=7.0
COMFYUI_SAMPLER=dpmpp_2m_sde
COMFYUI_SCHEDULER=karras
COMFYUI_GENERATE_TIMEOUT_S=180

# --- ComfyUI WAN 2.2 image-to-video (D-61) ---
# Requires WAN 2.2 weights on the ComfyUI host (scripts/dev/provision-olares-comfyui-models.ps1).
# When false (default) or on any failure, the cinematic FFmpeg slideshow is used.
VIDEO_I2V_ENABLED=false
VIDEO_I2V_WORKFLOW=wan22_i2v.json
VIDEO_I2V_WIDTH=832
VIDEO_I2V_HEIGHT=480
VIDEO_I2V_FRAMES=81
VIDEO_I2V_FPS=16
VIDEO_I2V_STEPS=20
VIDEO_I2V_TIMEOUT_S=600

# --- Olares desktop (optional overrides) ---
OLARES_HOST=olares@10.0.0.34
OLARES_API_CLUSTER_IP=10.233.21.231
OLARES_API_LOCAL_PORT=18000
