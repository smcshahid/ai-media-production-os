# Normalize line endings: LF in the repo for code/config; avoid CRLF churn on Windows.
* text=auto eol=lf

# Explicitly LF for source and config
*.py    text eol=lf
*.ts    text eol=lf
*.tsx   text eol=lf
*.js    text eol=lf
*.json  text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.md    text eol=lf
*.sh    text eol=lf
*.toml  text eol=lf
Makefile text eol=lf

# Windows scripts keep CRLF
*.ps1   text eol=crlf

# Binary assets — never normalize
*.png   binary
*.jpg   binary
*.webp  binary
*.gif   binary
*.pdf   binary
